# Copie ce fichier en .env.local (dev) ou configure ces variables en prod.

# --- Stockage (optionnel) ---
# Dossier de la base SQLite + des images uploadées (défaut: ./data)
# DATA_DIR=./data
# URL libSQL explicite (sinon dérivée de DATA_DIR)
# DATABASE_URL=file:./data/tierlistrr.db

# --- IA (optionnel) ---
# Sans clé, le bouton "Générer" est masqué et l'app fonctionne normalement.
# Clé gratuite : https://console.groq.com
# GROQ_API_KEY=gsk_xxx
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# POLLINATIONS_BASE_URL=https://image.pollinations.ai
# POLLINATIONS_TOKEN=sk_xxx   # clé SECRÈTE (sk_) de auth.pollinations.ai — usage serveur, sans limite
# IMAGE_CONCURRENCY=2

# --- Auth (better-auth, code OTP par email) ---
# REQUIS en prod : chaîne aléatoire (ex. `openssl rand -base64 32`)
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=https://tierlistrr.example.com
# Envoi des emails (Gmail Workspace : host smtp.gmail.com + mot de passe d'application)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   # mot de passe d'application Google (pas le mot de passe du compte)
# SMTP_FROM=tierlistrr <you@example.com>
