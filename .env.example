# Copy to .env.local (dev) or set these in your platform's environment (prod).

# --- Storage (optional) ---
# Directory for the SQLite database + uploaded images (default: ./data)
# DATA_DIR=./data
# Explicit libSQL URL (otherwise derived from DATA_DIR)
# DATABASE_URL=file:./data/tierlistrr.db

# --- Auth (better-auth, email OTP) ---
# REQUIRED in production: a random string (e.g. `openssl rand -base64 32`)
# BETTER_AUTH_SECRET=
# Your public app URL
# BETTER_AUTH_URL=https://tierlistrr.example.com
# Optional allowlist — only these may sign in (emails and/or @domains,
# comma-separated). Leave empty to allow everyone.
# AUTH_ALLOWED_EMAILS=alice@example.com, bob@example.com, @yourteam.com
# Email delivery for sign-in codes (e.g. Gmail: smtp.gmail.com + an App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   # provider app password (not your account password)
# SMTP_FROM=tierlistrr <you@example.com>

# --- AI (optional) ---
# Without a key the "Generate" button is hidden and the app works normally.
# Free key: https://console.groq.com
# GROQ_API_KEY=gsk_xxx
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# POLLINATIONS_BASE_URL=https://image.pollinations.ai
# POLLINATIONS_TOKEN=sk_xxx   # SECRET key (sk_) from auth.pollinations.ai — server-side, no rate limit
# IMAGE_CONCURRENCY=2

# --- Deployment (Traefik, optional) ---
# TIERLISTRR_HOST=tierlistrr.example.com
