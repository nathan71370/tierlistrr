# Copie ce fichier en .env.local (dev) ou configure ces variables en prod.

# --- Stockage (optionnel) ---
# Dossier de la base SQLite + des images uploadées (défaut: ./data)
# DATA_DIR=./data
# URL libSQL explicite (sinon dérivée de DATA_DIR)
# DATABASE_URL=file:./data/tierlistrr.db

# --- IA (optionnel) ---
# Sans clé, le bouton "Générer" est masqué et l'app fonctionne normalement.
# Clé gratuite : https://console.groq.com
# GROQ_API_KEY=gsk_xxx
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
